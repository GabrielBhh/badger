# Hand-written to match PKGBUILD. MUST be regenerated with
# `makepkg --printsrcinfo > .SRCINFO` (after fixing sha256sums against the
# real tag tarball) before the first AUR publish.
pkgbase = badger-cleaner
	pkgdesc = A Mole-inspired system cleaner for CachyOS/Arch Linux
	pkgver = 0.9.0
	pkgrel = 1
	url = https://github.com/GabrielBhh/badger
	arch = x86_64
	arch = aarch64
	license = MIT
	makedepends = cargo
	depends = gcc-libs
	optdepends = pacman-contrib: paccache support for package-cache cleanup
	optdepends = flatpak: flatpak cache/unused-app cleanup
	optdepends = snapper: btrfs snapshot cleanup
	optdepends = podman: container prune support
	optdepends = docker: container prune support
	optdepends = plocate: updatedb optimize task
	optdepends = reflector: mirror-ranking optimize task
	provides = badger-cleaner
	conflicts = badger-cleaner-bin
	source = badger-cleaner-0.9.0.tar.gz::https://github.com/GabrielBhh/badger/archive/refs/tags/v0.9.0.tar.gz
	sha256sums = SKIP

pkgname = badger-cleaner
