# Maintainer: Gabriel <gabriel.bh@gmail.com>
pkgname=badger-cleaner
pkgver=0.9.0
pkgrel=1
pkgdesc="A Mole-inspired system cleaner for CachyOS/Arch Linux"
arch=('x86_64' 'aarch64')
url="https://github.com/GabrielBhh/badger"
license=('MIT')
depends=('gcc-libs')
makedepends=('cargo')
provides=('badger-cleaner')
conflicts=('badger-cleaner-bin')
optdepends=(
  'pacman-contrib: paccache support for package-cache cleanup'
  'flatpak: flatpak cache/unused-app cleanup'
  'snapper: btrfs snapshot cleanup'
  'podman: container prune support'
  'docker: container prune support'
  'plocate: updatedb optimize task'
  'reflector: mirror-ranking optimize task'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/GabrielBhh/badger/archive/refs/tags/v$pkgver.tar.gz")
# Placeholder — this tarball does not exist yet (no tag has been published).
# Regenerate with `updpkgsums` (or `makepkg -g`) against the real v$pkgver tag
# before this package is ever submitted to the AUR.
sha256sums=('SKIP')

prepare() {
  cd "badger-$pkgver"
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "badger-$pkgver"
  cargo build --release --frozen
}

package() {
  cd "badger-$pkgver"

  install -Dm755 "target/release/badger" "$pkgdir/usr/bin/badger"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  install -d "$pkgdir/usr/share/bash-completion/completions"
  install -d "$pkgdir/usr/share/zsh/site-functions"
  install -d "$pkgdir/usr/share/fish/vendor_completions.d"

  "./target/release/badger" completion bash > "$pkgdir/usr/share/bash-completion/completions/badger"
  "./target/release/badger" completion zsh > "$pkgdir/usr/share/zsh/site-functions/_badger"
  "./target/release/badger" completion fish > "$pkgdir/usr/share/fish/vendor_completions.d/badger.fish"

  # Generates badger.1 plus one page per subcommand directly into place.
  "./target/release/badger" __mangen "$pkgdir/usr/share/man/man1"
}
