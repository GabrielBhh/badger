# Hand-written to match PKGBUILD. MUST be regenerated with
# `makepkg --printsrcinfo > .SRCINFO` (after filling in the real release
# checksums) before the first AUR publish.
pkgbase = badger-cleaner-bin
	pkgdesc = A Mole-inspired system cleaner for CachyOS/Arch Linux (prebuilt binary)
